generator client {
  provider     = "prisma-client"
  output       = "../prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model adress {
  id         Int        @id @unique(map: "id_UNIQUE") @default(autoincrement())
  street     String     @db.VarChar(85)
  city       String     @db.VarChar(45)
  postalCode String     @db.VarChar(30)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt()
  festival   festival[]
  profile    profile[]

  @@unique([street,city,postalCode])
}

model artist {
  id                  Int                   @id @unique(map: "id_UNIQUE") @default(autoincrement())
  artist_name         String                @db.VarChar(45)
  show_duration       Int                   
  time_start          DateTime           
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt()
  artist_has_stage    artist_has_stage[]
  festival_has_artist festival_has_artist[]
}



model artist_has_stage {
  artist_id  Int
  stage_id   Int
  artist     artist   @relation(fields: [artist_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_artist_has_stage_artist1")
  stage      stage    @relation(fields: [stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_artist_has_stage_stage1")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()

  @@id([artist_id, stage_id])
  @@index([artist_id], map: "fk_artist_has_stage_artist1_idx")
  @@index([stage_id], map: "fk_artist_has_stage_stage1_idx")
}

model festival {
  id                  Int                   @id @default(autoincrement())
  start_date          DateTime              @db.Date
  end_date            DateTime              @db.Date
  name                String                @db.VarChar(45)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt()
  adress_id           Int
  adress              adress                @relation(fields: [adress_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_festival_adress1")
  festival_has_artist festival_has_artist[]
  festival_has_stage  festival_has_stage[]
  mission             mission[]
  user_has_festival   user_has_festival[]


  @@index([adress_id], map: "fk_festival_adress1_idx")
  @@index([start_date,end_date])
  
}

model festival_has_artist {
  artist_id   Int
  festival_id Int
  stage_id    Int
  artist      artist   @relation(fields: [artist_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_artist_has_festival_artist1")
  festival    festival @relation(fields: [festival_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_artist_has_festival_festival1")
  stage       stage    @relation(fields: [stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_artist_has_festival_stage1")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt()

  @@id([artist_id, festival_id, stage_id])
  @@index([artist_id], map: "fk_artist_has_festival_artist1_idx")
  @@index([festival_id], map: "fk_artist_has_festival_festival1_idx")
  @@index([stage_id], map: "fk_artist_has_festival_stage1_idx")
}

model festival_has_stage {
  festival_id Int
  stage_id    Int
  festival    festival @relation(fields: [festival_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_festival_has_stage_festival1")
  stage       stage    @relation(fields: [stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_festival_has_stage_stage1")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt()

  @@id([festival_id, stage_id])
  @@index([festival_id], map: "fk_festival_has_stage_festival1_idx")
  @@index([stage_id], map: "fk_festival_has_stage_stage1_idx")
}

model inscription {
  mission_id Int
  user_id    Int
  mission    mission  @relation(fields: [mission_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mission_has_user_mission1")
  user       user     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mission_has_user_user1")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()

  @@id([mission_id, user_id])
  @@index([mission_id], map: "fk_mission_has_user_mission1_idx")
  @@index([user_id], map: "fk_mission_has_user_user1_idx")
}

model mission {
  id                   Int                    @id @unique(map: "id_UNIQUE") @default(autoincrement())
  title                String                 @db.VarChar(100)
  volunteer_needed     Int
  description          String                 @db.LongText
  is_full              Boolean                @db.TinyInt @default(false)
  time_start           DateTime
  time_end             DateTime  
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt()
  festival_id          Int
  inscription          inscription[]
  festival             festival               @relation(fields: [festival_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mission_festival1")


  @@index([festival_id], map: "fk_mission_festival1_idx")
}


model notification {
  id                    Int                     @id @unique(map: "id_UNIQUE") @default(autoincrement())
  message               String                  @db.Text
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt()
  notification_has_user notification_has_user[]
}

model notification_has_user {
  notification_id Int
  user_id         Int
  notification    notification @relation(fields: [notification_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notification_has_user_notification1")
  user            user         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notification_has_user_user1")
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt()

  @@id([notification_id, user_id])
  @@index([notification_id], map: "fk_notification_has_user_notification1_idx")
  @@index([user_id], map: "fk_notification_has_user_user1_idx")
}

model profile {
  id         Int      @id
  firstname  String   @db.VarChar(45)
  lastname   String   @db.VarChar(45)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()
  adress_id  Int?
 
  adress     adress?  @relation(fields: [adress_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_profile_adress1")
  user       user     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([adress_id], map: "fk_profile_adress1_idx")
}

model skills {
  id                  Int                   @id @unique(map: "id_UNIQUE") @default(autoincrement())
  name                String                @unique(map: "name_UNIQUE") @db.VarChar(45)
  description         String                @db.MediumText
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt()

  skills_has_user     skills_has_user[]
}

model skills_has_user {
  skills_id  Int
  user_id    Int
  skills     skills   @relation(fields: [skills_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_skills_has_user_skills1")
  user       user     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_skills_has_user_user1")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()

  @@id([skills_id, user_id])
  @@index([skills_id], map: "fk_skills_has_user_skills1_idx")
  @@index([user_id], map: "fk_skills_has_user_user1_idx")
}

model stage {
  id                  Int                   @id @unique(map: "id_UNIQUE") @default(autoincrement())
  stage_name          String                @db.VarChar(45)
  is_free             Int                   @db.TinyInt
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt()
  artist_has_stage    artist_has_stage[]
  festival_has_artist festival_has_artist[]
  festival_has_stage  festival_has_stage[]
}

model user {
  id                    Int                     @unique(map: "id_UNIQUE") @default(autoincrement())
  email                 String                  @unique(map: "email_UNIQUE") @db.VarChar(45)
  password              String                  @db.VarChar(90)
  is_validated          Boolean                 @default(false)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt()
  role                  role
  inscription           inscription[]
  notification_has_user notification_has_user[]
  skills_has_user       skills_has_user[]
  user_has_festival     user_has_festival[]

  profile profile?
  @@id([id])
}

model user_has_festival {
  user_id     Int
  festival_id Int
  festival    festival @relation(fields: [festival_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_has_festival_festival1")
  user        user     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_has_festival_user1")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt()

  @@id([user_id, festival_id])
  @@index([festival_id], map: "fk_user_has_festival_festival1_idx")
  @@index([user_id], map: "fk_user_has_festival_user1_idx")
}

enum role {
  organisateur
  benevole
}
